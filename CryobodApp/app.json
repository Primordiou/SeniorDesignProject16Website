{
  "expo": {
    "name": "Cryobod",
    "slug": "cryobodapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/humancooler.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/humancooler.png",
      "resizeMode": "contain",
      "backgroundColor": "#020c18"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/humancooler.png",
        "backgroundColor": "#020c18"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT"
      ],
      "package": "com.anonymous.CryobodApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "react-native-ble-plx",
      "expo-build-properties"
    ],
    "extra": {
      "eas": {
        "projectId": "28e3661f-ba5c-47f5-b4c4-474259f16680"
      }
    }
  }
}
